# Google Generative AI API Key (for image generation)
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-api-key-here

# Anthropic API Key (for text generation script)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Anthropic API Key for frontend AI evaluation (used in browser)
# Same key, prefixed with VITE_ so Vite exposes it to the client
# ⚠️  Only use for local development — this key is visible in the browser!
VITE_ANTHROPIC_API_KEY=your-api-key-here
